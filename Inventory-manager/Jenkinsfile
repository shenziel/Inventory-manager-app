pipeline {
    agent {
        docker {
            image 'maven:3.9.9-eclipse-temurin-21'
            args '-v $HOME/.m2:/root/.m2'
        }
    }

    options { skipStagesAfterUnstable() }

    stages {
        stage('Build') {
            steps {
                dir('Inventory-manager') {
                    sh 'mvn -B -DskipTests clean package'
                }
            }
        }
        stage('Test') {
            steps {
                dir('Inventory-manager') {
                    sh 'mvn test'
                }
            }
            post { always { junit 'target/surefire-reports/*.xml' } }
        }
    }
}